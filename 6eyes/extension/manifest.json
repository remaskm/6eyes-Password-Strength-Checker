{
  "manifest_version": 3,
  "name": "Six Eyes",
  "version": "2.0",
  "description": "Real-time password strength analyzer — Six Eyes",
  "permissions": [],
  "icons": {
    "16":  "icons/icon16.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}